from PyInstaller.utils.hooks import collect_all

datas = [('memes', 'memes'), ('assets', 'assets'), ('csharp_validator', 'csharp_validator'), ('bundled_dotnet', 'bundled_dotnet'), ('csharp_syntax_check\\bin\\Release\\net8.0', 'csharp_syntax_check/bin/Release/net8.0')]
